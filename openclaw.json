  "integrations": {
    "required": [
      {
        "name": "supabase",
        "type": "database",
        "tables": [
          "anima_agent_logs",
          "anima_fractal_state",
          "anima_evolution_log",
          "anima_cost_tracker",
          "anima_master_profile"
        ],
        "env_vars": [
          "SUPABASE_URL",
          "SUPABASE_ANON_KEY",
          "SUPABASE_SERVICE_KEY"
        ],
        "setup": "setup/supabase_schema.sql"
      },
      {
        "name": "discord",
        "type": "messaging",
        "channels": 10,
        "env_vars": [
          "DISCORD_BOT_TOKEN",
          "DISCORD_GUILD_ID"
        ],
        "setup": "setup/discord_setup.js"
      },
      {
        "name": "openrouter",
        "type": "llm",
        "env_vars": [
          "OPENROUTER_API_KEY"
        ]
      }
    ],
    "optional": [
      {
        "name": "telegram",
        "type": "messaging",
        "env_vars": [
          "TELEGRAM_BOT_TOKEN",
          "TELEGRAM_CHAT_ID"
        ],
        "status": "stub"
      },
      {
        "name": "n8n",
        "type": "webhook",
        "status": "stub"
      },
      {
        "name": "helicone",
        "type": "proxy",
        "status": "stub"
      },
      {
        "name": "langfuse",
        "type": "tracing",
        "status": "stub"
      },
      {
        "name": "ollama",
        "type": "llm_fallback",
        "status": "stub"
      },
      {
        "name": "lark",
        "type": "messaging",
        "status": "stub"
      },
      {
        "name": "whatsapp_kapso",
        "type": "messaging",
        "status": "stub"
      },
      {
        "name": "stripe",
        "type": "payments",
        "status": "stub"
      }
    ]
  },
  "dashboard": {
    "framework": "next.js",
    "directory": "dashboard",
    "deployment": "vercel",
    "env_vars": [
      "NEXT_PUBLIC_SUPABASE_URL",
      "NEXT_PUBLIC_SUPABASE_ANON_KEY"
    ]
  },
  "setup": {
    "installer": "setup/install.sh",
    "verifier": "setup/verify.js",
    "daemon": "setup/pi_pulse_daemon.js"
  },
  "onboarding": {
    "modes": [
      "SPARK",
      "ORACLE",
      "WILD"
    ],
    "files": {
      "spark": "onboarding/SPARK_MODE.md",
      "oracle": "onboarding/ORACLE_MODE.md",
      "wild": "onboarding/WILD_MODE.md",
      "oracle_prompt": "onboarding/oracle_prompt.txt"
    }
  },
  "constants": {
    "phi": 1.6180339887,
    "pi": 3.1415926535,
    "euler": 2.7182818284,
    "harmonic_bridge": 1.2002,
    "fractal_max_depth": 5,
    "fibonacci_sequence": [
      1,
      1,
      2,
      3,
      5,
      8,
      13
    ]
  }
